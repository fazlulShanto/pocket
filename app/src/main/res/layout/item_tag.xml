<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/tagIconPreview"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/icon_bg"
            android:contentDescription="@string/tag_icon"
            android:padding="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_food" />

        <TextView
            android:id="@+id/tagName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tagType"
            app:layout_constraintStart_toEndOf="@+id/tagIconPreview"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="12dp"
            tools:text="Food" />

        <TextView
            android:id="@+id/tagKeyword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/reporting_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/tagType"
            app:layout_constraintStart_toStartOf="@+id/tagName"
            app:layout_constraintTop_toBottomOf="@+id/tagName"
            tools:text="chicken, lunch" />

        <TextView
            android:id="@+id/tagType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toStartOf="@+id/editTag"
            app:layout_constraintTop_toTopOf="@+id/tagName"
            tools:text="Expense" />

        <ImageView
            android:id="@+id/editTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_edit"
            app:tint="@color/black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/deleteTag"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/deleteTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
