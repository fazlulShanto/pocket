<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".view.reporting.ReportingFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/dimen_16"
        android:paddingTop="@dimen/dimen_24"
        android:paddingEnd="@dimen/dimen_16"
        android:paddingBottom="@dimen/dimen_24">

        <TextView
            android:id="@+id/reporting_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/open_sans_bold"
            android:text="@string/nav_reporting"
            android:textColor="@color/reporting_text_primary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/reporting_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_8"
            android:fontFamily="@font/open_sans_semibold"
            android:text="@string/text_reporting_subtitle"
            android:textColor="@color/reporting_text_secondary"
            android:textSize="16sp"
            tools:text="All-time totals and the latest monthly breakdown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_24"
            android:fontFamily="@font/open_sans_semibold"
            android:text="@string/text_reporting_all_time_total"
            android:textColor="@color/reporting_text_primary"
            android:textSize="18sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_16"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/reporting_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:padding="@dimen/dimen_16">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.05"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/reporting_income_card_bg"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/dimen_16">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.72"
                                android:fontFamily="@font/open_sans_semibold"
                                android:text="@string/text_total_income"
                                android:textColor="@color/reporting_on_tint_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/all_time_income_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dimen_8"
                                android:fontFamily="@font/open_sans_bold"
                                android:textColor="@color/income"
                                android:textSize="22sp"
                                tools:text="₹70,000" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_12"
                        app:cardBackgroundColor="@color/reporting_expense_card_bg"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/dimen_16">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.72"
                                android:fontFamily="@font/open_sans_semibold"
                                android:text="@string/text_total_expense"
                                android:textColor="@color/reporting_on_tint_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/all_time_expense_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dimen_8"
                                android:fontFamily="@font/open_sans_bold"
                                android:textColor="@color/expense"
                                android:textSize="22sp"
                                tools:text="₹48,000" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_12"
                        app:cardBackgroundColor="@color/reporting_savings_card_bg"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/dimen_16">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.72"
                                android:fontFamily="@font/open_sans_semibold"
                                android:text="@string/text_reporting_savings"
                                android:textColor="@color/reporting_on_tint_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/all_time_savings_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dimen_8"
                                android:fontFamily="@font/open_sans_bold"
                                android:textColor="@color/blue_500"
                                android:textSize="22sp"
                                tools:text="₹22,000" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/all_time_bar_chart"
                    android:layout_width="0dp"
                    android:layout_height="180dp"
                    android:layout_marginStart="@dimen/dimen_16"
                    android:layout_weight="1"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_24"
            android:fontFamily="@font/open_sans_semibold"
            android:text="@string/text_reporting_all_time_top_categories"
            android:textColor="@color/reporting_text_primary"
            android:textSize="18sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_16"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/reporting_card_stroke"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/all_time_categories_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/dimen_16">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/all_time_categories_chart"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no" />

                    <LinearLayout
                        android:id="@+id/all_time_categories_legend_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/dimen_16"
                        android:layout_weight="1"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/all_time_categories_empty_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/open_sans_regular"
                    android:paddingStart="@dimen/dimen_16"
                    android:paddingTop="@dimen/dimen_24"
                    android:paddingEnd="@dimen/dimen_16"
                    android:paddingBottom="@dimen/dimen_24"
                    android:text="@string/text_reporting_no_categories"
                    android:textColor="@color/reporting_text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_24"
            android:fontFamily="@font/open_sans_semibold"
            android:text="@string/text_reporting_monthly_breakdown"
            android:textColor="@color/reporting_text_primary"
            android:textSize="18sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_16"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/reporting_card_stroke"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="280dp">

                <LinearLayout
                    android:id="@+id/monthly_breakdown_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/dimen_16">

                    <TextView
                        android:id="@+id/monthly_breakdown_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/open_sans_bold"
                        android:textColor="@color/reporting_text_primary"
                        android:textSize="22sp"
                        tools:text="May 2026" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_16"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/dimen_8"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/reporting_income_card_bg"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:alpha="0.72"
                                    android:fontFamily="@font/open_sans_semibold"
                                    android:text="@string/text_total_income"
                                    android:textColor="@color/reporting_on_tint_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/monthly_income_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/dimen_8"
                                    android:fontFamily="@font/open_sans_bold"
                                    android:textColor="@color/income"
                                    android:textSize="18sp"
                                    tools:text="₹12,000" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/dimen_8"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/reporting_expense_card_bg"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:alpha="0.72"
                                    android:fontFamily="@font/open_sans_semibold"
                                    android:text="@string/text_total_expense"
                                    android:textColor="@color/reporting_on_tint_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/monthly_expense_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/dimen_8"
                                    android:fontFamily="@font/open_sans_bold"
                                    android:textColor="@color/expense"
                                    android:textSize="18sp"
                                    tools:text="₹7,850" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/reporting_savings_card_bg"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:alpha="0.72"
                                    android:fontFamily="@font/open_sans_semibold"
                                    android:text="@string/text_reporting_savings"
                                    android:textColor="@color/reporting_on_tint_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/monthly_savings_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/dimen_8"
                                    android:fontFamily="@font/open_sans_bold"
                                    android:textColor="@color/blue_500"
                                    android:textSize="18sp"
                                    tools:text="₹4,150" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/dimen_16"
                        android:background="@color/reporting_divider" />

                    <LinearLayout
                        android:id="@+id/monthly_category_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_16"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/monthly_category_empty_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_12"
                        android:fontFamily="@font/open_sans_regular"
                        android:text="@string/text_reporting_no_categories"
                        android:textColor="@color/reporting_text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/monthly_breakdown_empty_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/open_sans_regular"
                    android:text="@string/text_reporting_history_empty"
                    android:textColor="@color/reporting_text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/monthly_breakdown_history_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
